"""
Сканирование папок, поиск дубликатов и сравнение с резервной копией.
1. Каркас (приём пути, проверка существования папки)
2. Сканирование (ручной рекурсивный обход, сбор метаданных, фильтрация по расширению)
3. Дубликаты (расчёт хэша MD5, группировка одинаковых файлов)
4. Резервная копия (отсутствующие, лишние, изменённые файлы)
"""

import sys
import os
from scanner import scan_folder
from duplicates import find_duplicates
from backup import compare_with_backup, print_comparison_report

def main():
    if len(sys.argv) < 2:
        print("Ошибка: укажите путь к папке")
        print("Пример: python main.py C:\МоиДокументы")
        print("Пример с фильтром: python main.py C:\МоиДокументы .txt")
        print("Пример с бэкапом: python main.py C:\МоиДокументы C:\Бэкап")
        sys.exit(1)
    
    folder_path = sys.argv[1]
    
    backup_path = None
    extension = None
    
    if len(sys.argv) >= 3:
        if sys.argv[2].startswith('.'):
            extension = sys.argv[2]
        else:
            backup_path = sys.argv[2]
    
    if len(sys.argv) >= 4:
        if sys.argv[3].startswith('.'):
            extension = sys.argv[3]
    
    if not os.path.exists(folder_path):
        print(f"Ошибка: папка '{folder_path}' не существует")
        sys.exit(1)
    
    if not os.path.isdir(folder_path):
        print(f"Ошибка: '{folder_path}' - это не папка")
        sys.exit(1)
    
    if backup_path:
        if not os.path.exists(backup_path):
            print(f"Ошибка: папка бэкапа '{backup_path}' не существует")
            sys.exit(1)
        if not os.path.isdir(backup_path):
            print(f"Ошибка: '{backup_path}' - это не папка")
            sys.exit(1)
    
    if extension:
        if not extension.startswith('.'):
            extension = '.' + extension
        print(f"Фильтр: файлы с расширением {extension}")
    
    print(f"\nНачинаем сканирование исходной папки: {folder_path}")
    if backup_path:
        print(f"Папка бэкапа: {backup_path}")
    print()

    print("Сканирование исходной папки...")
    source_files = scan_folder(folder_path, extension)
    print(f"Найдено файлов: {len(source_files)}")

    if backup_path:
        print("Сканирование папки бэкапа...")
        backup_files = scan_folder(backup_path, extension)
        print(f"Найдено файлов: {len(backup_files)}")
        
        comparison_result = compare_with_backup(source_files, backup_files)
        print_comparison_report(comparison_result)
    
    print("МЕТАДАННЫЕ ИСХОДНОЙ ПАПКИ:")
    
    if len(source_files) <= 10:
        print("Список всех файлов:")
        for i, file_info in enumerate(source_files, 1):
            print(f"{i}. {file_info['path']}")
            print(f"   Размер: {file_info['size']} байт")
            print(f"   Изменён: {file_info['modified']}")
            if file_info['hash']:
                print(f"   Хэш: {file_info['hash'][:16]}...")
            print()
    else:
        print(f"Первые 10 файлов из {len(source_files)}:")
        for i, file_info in enumerate(source_files[:10], 1):
            print(f"{i}. {file_info['path']}")
            print(f"   Размер: {file_info['size']} байт")
            print(f"   Изменён: {file_info['modified']}")
            if file_info['hash']:
                print(f"   Хэш: {file_info['hash'][:16]}...")
            print()
        print(f"... и ещё {len(source_files) - 10} файлов")
    
    print("-" * 50)
    print("ПОИСК ДУБЛИКАТОВ:")
    
    duplicates = find_duplicates(source_files)
    
    if duplicates:
        print(f"Найдено групп дубликатов: {len(duplicates)}")
        print()
        for hash_val, paths in duplicates.items():
            print(f"Группа дубликатов (хэш: {hash_val[:16]}...):")
            for i, path in enumerate(paths, 1):
                print(f"  {i}. {path}")
            print()
    else:
        print("Дубликатов не найдено.")
    
    print()
    print("РАБОТА ЗАВЕРШЕНА!")

if __name__ == "__main__":
    main()
