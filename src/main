"""
Сканирование папок, поиск дубликатов и сравнение с резервной копией.
1. Каркас (приём пути, проверка существования папки)
2. Сканирование (ручной рекурсивный обход, сбор метаданных, фильтрация по расширению)
3. Дубликаты (расчёт хэша MD5, группировка одинаковых файлов)
4. Резервная копия (отсутствующие, лишние, изменённые файлы)
"""

import sys
import os
import datetime
import hashlib

# 3 -------------------------------------------------------

def calculate_hash(file_path, chunk_size=8192):
    # Считает хэш файла (MD5)
    hash_md5 = hashlib.md5()
    try:
        with open(file_path, "rb") as f:
            for chunk in iter(lambda: f.read(chunk_size), b""):
                hash_md5.update(chunk)
        return hash_md5.hexdigest()
    except (OSError, PermissionError):
        return None

def scan_folder(folder_path, extension=None):
    # Рекурсивно сканирует папку и собирает информацию о файлах
    files_info = []
    
    try:
        items = os.listdir(folder_path)
    except PermissionError:
        return files_info
    
    for item in items:
        full_path = os.path.join(folder_path, item)
        
        if os.path.isdir(full_path):
            sub_files = scan_folder(full_path, extension)
            files_info.extend(sub_files)
        else:
            if extension:
                if not full_path.lower().endswith(extension.lower()):
                    continue
            
            try:
                stat = os.stat(full_path)
                file_hash = calculate_hash(full_path)
                
                files_info.append({
                    'path': full_path,
                    'size': stat.st_size,
                    'modified': datetime.datetime.fromtimestamp(stat.st_mtime),
                    'hash': file_hash
                })
            except (OSError, PermissionError):
                continue
    
    return files_info

def find_duplicates(files_info):
    # Находит дубликаты по хэшу
    hash_groups = {}
    
    for file_info in files_info:
        file_hash = file_info.get('hash')
        if file_hash is None:
            continue
        
        if file_hash not in hash_groups:
            hash_groups[file_hash] = []
        hash_groups[file_hash].append(file_info['path'])
    
    duplicates = {h: paths for h, paths in hash_groups.items() if len(paths) > 1}
    return duplicates

# 4 ----------------------------------------------------------

def compare_with_backup(source_files, backup_files):
    # Сравнивает исходную папку с бэкапом по имени файла и хэшу
    # Создаем словари: имя файла - информация
    source_by_name = {}
    for info in source_files:
        name = os.path.basename(info['path'])
        source_by_name[name] = info
    
    backup_by_name = {}
    for info in backup_files:
        name = os.path.basename(info['path'])
        backup_by_name[name] = info
    
    source_names = set(source_by_name.keys())
    backup_names = set(backup_by_name.keys())
    
    missing = []
    extra = []
    modified = []
    same = []
    
    for name in source_names:
        if name not in backup_names:
            missing.append(name)
        else:
            source_hash = source_by_name[name].get('hash')
            backup_hash = backup_by_name[name].get('hash')
            
            if source_hash and backup_hash and source_hash == backup_hash:
                same.append(name)
            else:
                modified.append(name)
    
    for name in backup_names:
        if name not in source_names:
            extra.append(name)
    
    return {
        'missing': missing,
        'extra': extra,
        'modified': modified,
        'same': same
    }

def print_comparison_report(comparison_result):
    print()
    print("-" * 60)
    print("СРАВНЕНИЕ С РЕЗЕРВНОЙ КОПИЕЙ:")
    
    if comparison_result['missing']:
        print(f"\n Отсутствуют в бэкапе (есть в исходной): {len(comparison_result['missing'])}")
        for name in comparison_result['missing']:
            print(f"  - {name}")
    else:
        print("\n Все файлы присутствуют в бэкапе")
    
    if comparison_result['extra']:
        print(f"\n Лишние в бэкапе (нет в исходной): {len(comparison_result['extra'])}")
        for name in comparison_result['extra']:
            print(f"  - {name}")
    else:
        print("\n В бэкапе нет лишних файлов")
    
    if comparison_result['modified']:
        print(f"\n Изменённые файлы: {len(comparison_result['modified'])}")
        for name in comparison_result['modified']:
            print(f"  - {name}")
    else:
        print("\n Все общие файлы совпадают")
    
    print(f"\n Совпадают: {len(comparison_result['same'])} файлов")
    
    print("-" * 60)

# 1 ------------------------------------------------------------------

def main():
    if len(sys.argv) < 2:
        print("Ошибка: укажите путь к папке")
        print("Пример: python main.py C:\МоиДокументы")
        print("Пример с фильтром: python main.py C:\МоиДокументы .txt")
        print("Пример с бэкапом: python main.py C:\МоиДокументы C:\Бэкап")
        sys.exit(1)
    
    folder_path = sys.argv[1]
    
    backup_path = None
    extension = None
    
    if len(sys.argv) >= 3:
        if sys.argv[2].startswith('.'):
            extension = sys.argv[2]
        else:
            backup_path = sys.argv[2]
    
    if len(sys.argv) >= 4:
        if sys.argv[3].startswith('.'):
            extension = sys.argv[3]
    
    if not os.path.exists(folder_path):
        print(f"Ошибка: папка '{folder_path}' не существует")
        sys.exit(1)
    
    if not os.path.isdir(folder_path):
        print(f"Ошибка: '{folder_path}' - это не папка")
        sys.exit(1)
    
    if backup_path:
        if not os.path.exists(backup_path):
            print(f"Ошибка: папка бэкапа '{backup_path}' не существует")
            sys.exit(1)
        if not os.path.isdir(backup_path):
            print(f"Ошибка: '{backup_path}' - это не папка")
            sys.exit(1)
    
    if extension:
        if not extension.startswith('.'):
            extension = '.' + extension
        print(f"Фильтр: файлы с расширением {extension}")
    
    print(f"\nНачинаем сканирование исходной папки: {folder_path}")
    if backup_path:
        print(f"Папка бэкапа: {backup_path}")
    print()
    
# 2 --------------------------------------------------------------

    print("Сканирование исходной папки...")
    source_files = scan_folder(folder_path, extension)
    print(f"Найдено файлов: {len(source_files)}")
    
    if backup_path:
        print("Сканирование папки бэкапа...")
        backup_files = scan_folder(backup_path, extension)
        print(f"Найдено файлов: {len(backup_files)}")
        
        comparison_result = compare_with_backup(source_files, backup_files)
        print_comparison_report(comparison_result)
    
    print("МЕТАДАННЫЕ ИСХОДНОЙ ПАПКИ:")
    
    if len(source_files) <= 10:
        print("Список всех файлов:")
        for i, file_info in enumerate(source_files, 1):
            print(f"{i}. {file_info['path']}")
            print(f"   Размер: {file_info['size']} байт")
            print(f"   Изменён: {file_info['modified']}")
            if file_info['hash']:
                print(f"   Хэш: {file_info['hash'][:16]}...")
            print()
    else:
        print(f"Первые 10 файлов из {len(source_files)}:")
        for i, file_info in enumerate(source_files[:10], 1):
            print(f"{i}. {file_info['path']}")
            print(f"   Размер: {file_info['size']} байт")
            print(f"   Изменён: {file_info['modified']}")
            if file_info['hash']:
                print(f"   Хэш: {file_info['hash'][:16]}...")
            print()
        print(f"... и ещё {len(source_files) - 10} файлов")
    
    print("-" * 50)
    print("ПОИСК ДУБЛИКАТОВ:")
    
    duplicates = find_duplicates(source_files)
    
    if duplicates:
        print(f"Найдено групп дубликатов: {len(duplicates)}")
        print()
        for hash_val, paths in duplicates.items():
            print(f"Группа дубликатов (хэш: {hash_val[:16]}...):")
            for i, path in enumerate(paths, 1):
                print(f"  {i}. {path}")
            print()
    else:
        print("Дубликатов не найдено.")
    
    print()
    print("РАБОТА ЗАВЕРШЕНА!")

if __name__ == "__main__":
    main()
